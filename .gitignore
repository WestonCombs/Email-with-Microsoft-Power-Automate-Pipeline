.env
.env.*
!.env.example

# Launcher Settings (secrets); optional copy as email_sorter_settings.example.json without values
email_sorter_settings.json

# MSAL delegated token cache (do not commit)
.graph_token_cache.bin

# Python
__pycache__/
*.py[cod]

# Excel clipboard launcher (local python.exe paths)
excel_clipboard_launch.ini

# Logs may contain emails, paths, names, and order details
adminLog/
run_log.txt
trackingLinkConsoleOutput.txt
EnvironmentInitialization/console_log

# PDF capture (mitmproxy): debug-mode-only mitmdump logs; legacy capture filenames
**/mitmdump.stdout.log
**/mitmdump.stderr.log
**/mitm_out.txt
**/mitm_err.txt
**/pdf_capture_session.log

# PDF capture: Chrome profile (cache, IndexedDB, GPUCache, cookies, etc.) — recreated at runtime
**/chrome_user_data_mitm/

# PDF capture: downloaded PDFs and session marker when runtime dir is under the repo
pdfCaptureFromChrome/captured_pdfs/
**/.pdfCaptureFromChrome_done.json

# PDF capture runtime when BASE_DIR is set (see pdfCaptureFromChrome/paths.py)
logs/pdfCaptureFromChrome/

# Codex: autogenerated environment config (machine-specific paths)
.codex/

# Tool / package caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Windows Explorer metadata
Thumbs.db
ehthumbs.db
Desktop.ini
