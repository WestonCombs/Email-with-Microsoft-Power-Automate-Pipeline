# Copy this file to .env and fill in values. Never commit .env.
# BASE_DIR is the single project root: email_contents/, programFileOutput.txt, adminLog/, etc.
BASE_DIR=
OPENAI_API_KEY=
DEMO_MODE=0
# Plain-text cap after HTML→text (chars toward OpenAI). Default 50000 if unset or invalid.
openai_max_chars_per_prompting=200000

# ── IMAP email settings (used by mainRunner.py) ──
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USE_SSL=1
IMAP_USERNAME=
IMAP_PASSWORD=
# Which mailbox folder to fetch emails from (e.g. INBOX, Test1, Label/SubLabel)
IMAP_MAIL_FOLDER=INBOX
