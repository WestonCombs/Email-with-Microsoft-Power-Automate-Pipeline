# Copy this file to .env and fill in values. Never commit .env.
# BASE_DIR is the single project root: email_contents/, programFileOutput.txt, logs/, adminLog/, etc.
BASE_DIR=
OPENAI_API_KEY=
DEMO_MODE=0

# ── Logging & debug ──────────────────────────────────────────────────────────
# DEBUG_MODE=1 — writes extra detail to BASE_DIR/logs/debug_<segment>.txt files.
# Console output stays clean regardless of this setting.
DEBUG_MODE=0

# Plain-text cap after HTML→text (chars toward OpenAI). Default 50000 if unset or invalid.
openai_max_chars_per_prompting=200000
# Optional: set to 1 to append HTML/text snippets inside adminLog/htmlHandler_trace.txt entries.
#TRACE_INCLUDE_SAMPLES=0

# ── Microsoft Graph (OAuth 2.0) ——
# Azure Portal → App registrations → your app → Application (client) ID
AZURE_CLIENT_ID=
# Azure AD tenant: your tenant GUID, or "common" for personal + work/school sign-in
AZURE_TENANT_ID=common
# interactive = browser login (default). device_code = print a code and use another device.
GRAPH_AUTH_FLOW=interactive
# Folder display name (e.g. INBOX, Shopping) — same idea as the old IMAP folder setting
GRAPH_MAIL_FOLDER= #Folder Name Here
# Optional: path to MSAL token cache file 
#GRAPH_TOKEN_CACHE_PATH=

