# Copy this file to .env and fill in values. Never commit .env.
# BASE_DIR — project root (email_contents/, logs/, …). Set in Email Sorter → Settings only; Save writes it here.
BASE_DIR=
OPENAI_API_KEY=
DEMO_MODE=0

# ── Logging & debug ──────────────────────────────────────────────────────────
# DEBUG_MODE=1 — writes extra detail to BASE_DIR/logs/debug_<segment>.txt files.
# Also shows Excel columns: View Tracking Links, View Tracking Numbers, View Tracking Numbers (All For Order).
# When DEBUG_MODE=0, those three columns are hidden; Shipping Status (click opens status viewer) stays visible.
# With DEBUG_MODE=1, email_sorter_launcher “Run” asks: full mailbox pipeline vs Excel-only from existing results.json.
# Console output stays clean regardless of this setting.
DEBUG_MODE=0

# Plain-text cap after HTML→text (chars toward OpenAI). Default 50000 if unset or invalid.
# Example below raises the cap; omit or lower if you want the default.
openai_max_chars_per_prompting=200000
# Optional: set to 1 to append HTML/text snippets inside logs/htmlHandler.txt trace entries.
#TRACE_INCLUDE_SAMPLES=0

# ── Link extraction (optional) ───────────────────────────────────────────────
# Verbose href logging when 1 (or when DEBUG_MODE=1).
#EMAIL_LINK_DEBUG=0
# Parallel HTTP workers when resolving tracking links (default 12).
#HREF_RESOLVE_MAX_WORKERS=12

# ── Microsoft Graph (OAuth 2.0) ——
# Azure Portal → App registrations → your app → Application (client) ID
AZURE_CLIENT_ID=
# Azure AD tenant: your tenant GUID, or "common" for personal + work/school sign-in
AZURE_TENANT_ID=common
# interactive = browser login (default). device_code = print a code and use another device.
GRAPH_AUTH_FLOW=interactive
# Folder display name (e.g. INBOX, Shopping) — same idea as the old IMAP folder setting
GRAPH_MAIL_FOLDER= #Folder Name Here
# Legacy alias: used only if GRAPH_MAIL_FOLDER is empty (same value as old IMAP setting).
#IMAP_MAIL_FOLDER=
# Optional: path to MSAL token cache file
#GRAPH_TOKEN_CACHE_PATH=

# ── OpenAI / PDF conversion (optional; mainRunner sets these when printing HTML to PDF) ──
# When 1, html→PDF uses Outlook-style header lines from the OUTLOOK_* vars below.
#OUTLOOK_PREPEND_PDF_HEADER=0
#OUTLOOK_FROM_RAW=
#OUTLOOK_TO_LINE=
#OUTLOOK_SENT_LINE=
#OUTLOOK_HEADER_TITLE=
# Override default OpenAI usage log dir (<BASE_DIR>/logs/openai usage/).
#OPENAI_USAGE_LOG_PATH=
# Timing buffer path (mainRunner sets next to usage logs when running the pipeline).
#TIMING_BUFFER_PATH=

# ── Excel (optional) ─────────────────────────────────────────────────────────
# Default output: <BASE_DIR>/email_contents/orders.xlsm when the macro template exists.
# Default macro template: <BASE_DIR>/email_contents/orders_template.xlsm.
# Clipboard ini defaults to python_files/excel_clipboard_launch.ini unless EXCEL_CLIPBOARD_INI_PATH is set.
#EXCEL_OUTPUT_PATH=
#EXCEL_TEMPLATE_PATH=
#EXCEL_CLIPBOARD_INI_PATH=
# Row background: default = alternate green/blue by order number (gift rows yellow; no order id = purple).
# Set to 1 to restore legacy coloring by email category (Invoice/Shipped/Delivered/…).
#EXCEL_LEGACY_CATEGORY_ROW_COLORS=0
# Set to 1/true to force regeneration of orders_template.xlsm from macro_template (advanced).
#FORCE_REBUILD_ORDERS_TEMPLATE=0

# ── Package tracking (optional) ─────────────────────────────────────────────
# 17TRACK API key (free tier): https://user.17track.net — used by tracking viewers and optional prefetch.
# Official UPS/FedEx/USPS REST APIs require separate developer accounts (OAuth); not bundled here.
#SEVENTEEN_TRACK_API_KEY=
# Alias for SEVENTEEN_TRACK_API_KEY (either name works).
#17TRACK_API_KEY=
# createExcelDocument prefetches 17TRACK for all tracking IDs (deduped) before writing the workbook
# when SEVENTEEN_TRACK_API_KEY is set. Disk cache: email_contents/tracking_status_cache/
# Minimum seconds between gettrackinfo calls per ID for *terminal* shipments (non-terminal refreshes each run).
#SEVENTEEN_TRACK_MIN_INTERVAL_SEC=3600
# The launcher sets these for Run/Excel flows (path to a one-line flag file; quota session). Usually leave unset.
#EMAIL_SORTER_17TRACK_SKIP_FLAG=
#EMAIL_SORTER_17TRACK_QUOTA_SESSION=0

# ── PDF capture / mitmproxy (optional) ──────────────────────────────────────
# If mitmdump fails with "address already in use" / WinError 10048, another process owns that port — use a free port:
#PDF_CAPTURE_MITM_PORT=8082
# Advanced: run_pdf_capture sets these; override only if driving mitmdump manually.
#PDF_INTERCEPTOR_OUTPUT_DIR=
#PDF_INTERCEPTOR_BASENAME=captured
# Comma-separated URL substrings to allow saving a PDF (default: proof,delivery,pod,label,tracking,shipment,invoice,fedex,ups).
#PDF_INTERCEPTOR_URL_KEYWORDS=
#PDF_INTERCEPTOR_REQUIRE_URL_KEYWORD=1
#PDF_INTERCEPTOR_MAX_PDFS=
#PDF_CAPTURE_DONE_FILE=

# ── Launcher subprocess flags (do not set in .env for normal use) ───────────
# email_sorter_launcher sets EMAIL_SORTER_LAUNCHER_PROGRESS / EXCEL_LAUNCHER_PROGRESS when showing progress UI.
